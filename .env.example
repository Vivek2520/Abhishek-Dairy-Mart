# Server Configuration
PORT=5000
NODE_ENV=development

# Data Files
DATA_DIR=.
PRODUCTS_FILE=products.json
ORDERS_FILE=orders.json

# WhatsApp Configuration
WHATSAPP_PHONE=917879355368

# CORS Configuration
CORS_ORIGIN=*

# API Configuration
# Rate limiting window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Rate limit max requests per window (default: 100)
RATE_LIMIT_MAX=100

# Authentication
JWT_SECRET=your_jwt_secret_32_characters_minimum

# Export/Excel paths
EXPORTS_DIR=./exports

# Data warehouse (Postgres example)
WAREHOUSE_DB_URL=postgres://user:pass@host:5432/dbname

# SMTP (for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Application URL (used when generating reset link)
APP_URL=http://localhost:5000

# Email OTP
EMAIL_OTP_TTL_MINUTES=10

# Google Sign-In
GOOGLE_CLIENT_ID=

# MongoDB Configuration (optional - uses JSON storage as fallback)
# Local MongoDB: mongodb://localhost:27017/abhishek-dairy
# Remote MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/abhishek-dairy
MONGODB_URI=mongodb://localhost:27017/abhishek-dairy

# Database selection (default: false for JSON storage)
USE_MONGODB=false
