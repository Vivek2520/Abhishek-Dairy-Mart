## Backend Environment Configuration Example\n\n# JWT & Security\nJWT_SECRET=your-64-char-jwt-secret-key-here-change-in-production\nADMIN_PASSWORD_HASH=$2a$10$... (bcrypt hash for admin password)\n\n# Database\nDB_HOST=localhost\nDB_USER=root\nDB_PASSWORD=\nDB_NAME=mywebsite_db\n\n# CORS\nCORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://yourdomain.com\n\n# Rate Limiting (optional - uses config defaults if not set)\nRATE_LIMIT_WINDOW=15  # minutes\nRATE_LIMIT_MAX=100    # requests per window\nLOGIN_RATE_LIMIT_MAX=5\n\n# Server\nNODE_ENV=production\nPORT=5000
