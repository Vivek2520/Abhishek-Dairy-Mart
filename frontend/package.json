{
  "name": "frontend-optimization",
  "version": "1.0.0",
  "description": "E-commerce Frontend Optimization",
  "scripts": {
    "minify:css": "postcss public/**/*.css -d dist/css/ --use autoprefixer cssnano",
    "minify:js": "terser public/**/*.js -o 'dist/js/' --compress --mangle"
  },
  "devDependencies": {
    "terser": "^5.24.0",
    "cssnano": "^7.0.3",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "autoprefixer": "^10.4.19"
  }
}
